remove the duplicate(sorted array)
class Solution {
    ArrayList<Integer> remDuplicate(int arr[]) {
        ArrayList<Integer> list = new ArrayList<>();

        int n = arr.length;
        for(int i = 0; i < n - 1; i++) {
            if(arr[i] != arr[i + 1]) {
                list.add(arr[i]);
            }
        }
        list.add(arr[n - 1]);
        return list;
    }
}

remove the duplicate(unsorted array)
class Solution {
    ArrayList<Integer> remDuplicate(int arr[]) {
        HashSet<Integer> set=new HashSet<>();
        int n=arr.length;
        for(int i=0;i<n;i++){
            set.add(arr[i]);
        }
        ArrayList <Integer> list=new ArrayList<>(set);
        return list;
    }
}
